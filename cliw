set -e
# https://stackoverflow.com/a/29835459
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
deno_dir="$script_dir/.deno"

# https://manpages.ubuntu.com/manpages/kinetic/en/man1/chronic.1.html
chronic() (
  set +e
  output=$($@ 2>&1)
  exit_code=$?
  set -e
  if [ "$exit_code" -ne 0 ]; then
    echo "$output" >&2
  fi
  return "$exit_code"
)

if [ ! -d "$deno_dir" ]; then
  # https://github.com/denoland/deno_install#readme
  export DENO_INSTALL=$deno_dir
  # Download the install script to a temp file before executing it.
  # This avoids the unsafe "curl | sh" pattern where a compromised remote
  # server could execute arbitrary code on the runner before the shell even
  # sees the script content.
  install_script=$(mktemp)
  curl -fsSL -o "$install_script" https://deno.land/x/install/install.sh
  chronic sh "$install_script" -s "v1.35.1"
  rm -f "$install_script"
fi

# https://github.com/denoland/deno_install/blob/master/install.sh#L53
export DENO_INSTALL=$deno_dir
export PATH="$DENO_INSTALL/bin:$PATH"

exec "$script_dir/cli.ts" "$@"
